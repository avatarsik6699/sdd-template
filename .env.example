# [PROJECT_NAME] — environment template
# Copy to .env and fill in values. NEVER commit .env.

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://app_user:changeme@db:5432/myapp
POSTGRES_USER=app_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=myapp

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=changeme_redis
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Auth ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_generate_a_secure_random_hex_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:80"]

# ── App ───────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO

# ── Frontend ──────────────────────────────────────────────
# SSR-side internal URL (Docker network, server-to-server)
API_BASE_URL=http://backend:8000
# Browser-side public URL (set to domain in production)
# Nuxt автоматически маппит NUXT_PUBLIC_<KEY> → runtimeConfig.public.<camelKey>
NUXT_PUBLIC_API_BASE=http://localhost:8000

# ── Production (заполнить на VPS) ─────────────────────────
DOMAIN=[DOMAIN]
# В production:
# API_BASE_URL=http://backend:8000          (без изменений, internal Docker)
# NUXT_PUBLIC_API_BASE=https://[DOMAIN] (публичный URL для браузера)
# CORS_ORIGINS=["https://[DOMAIN]","https://www.[DOMAIN]"]
# APP_ENV=production
