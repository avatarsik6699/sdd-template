{
  "name": "frontend",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "generate:api": "node --env-file=.env scripts/generate-api.js",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium",
    "test:e2e:all": "playwright test --project=chromium --project=firefox --project=webkit",
    "test:e2e:lint": "node scripts/check-e2e-anti-flake.mjs",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps",
    "typecheck": "vue-tsc --build --noEmit"
  },
  "dependencies": {
    "@nuxt/ui": "^4.6.1",
    "@nuxtjs/i18n": "^10.2.4",
    "@pinia/nuxt": "^0.11.3",
    "nuxt": "^4.4.2",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-plugin-prettier": "^5",
    "eslint-plugin-vue": "^9",
    "globals": "^16",
    "happy-dom": "^16.0.0",
    "openapi-typescript": "^7.13.0",
    "prettier": "^3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8",
    "vitest": "^4.1.4",
    "vue-eslint-parser": "^9",
    "vue-tsc": "^3.2.7"
  }
}
